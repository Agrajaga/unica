#Область ПрограммныйИнтерфейс

Функция НовоеСообщение() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Вид", "request");
	Результат.Вставить("ИмяСобытия", "");
	Результат.Вставить("Ид", "");
	Результат.Вставить("ТипЗначения", "undefined");
	Результат.Вставить("Значение", Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьПакет(Значение)
	
	Результат = Новый Структура;
	Результат.Вставить("Тип", "undefined");
	Результат.Вставить("Данные", "");
	
	Если Значение = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(Значение);
	
	Если ТипЗначения = Тип("Строка") Тогда
		Результат.Тип = "string";
		Результат.Данные = ЗаписатьЗначениеJSON(Значение);
	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		Результат.Тип = "bool";
		Результат.Данные = ЗаписатьЗначениеJSON(Значение);
	ИначеЕсли ТипЗначения = Тип("Число") Тогда
		Результат.Тип = "number";
		Результат.Данные = ЗаписатьЗначениеJSON(Значение);
	ИначеЕсли ТипЗначения = Тип("Структура")
		Или ТипЗначения = Тип("ФиксированнаяСтруктура")
		Или ТипЗначения = Тип("Соответствие")
		Или ТипЗначения = Тип("ФиксированноеСоответствие")
		Или ТипЗначения = Тип("Массив")
		Или ТипЗначения = Тип("ФиксированныйМассив") Тогда
		
		Результат.Тип = "json";
		Результат.Данные = ЗаписатьЗначениеJSON(Значение);
	ИначеЕсли ТипЗначения = Тип("ДвоичныеДанные") Тогда
		Результат.Тип = "blob";
		Результат.Данные = Base64Строка(Значение);
	Иначе
		Результат.Тип = "string";
		Результат.Данные = ЗаписатьЗначениеJSON(XMLСтрока(Значение));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ОбработатьСообщение(ЭтотОбъект, ЭлементПолеHTML, ДанныеСобытия, СтандартнаяОбработка, Обработчик) Экспорт
	
	ЭлементHTML = ДанныеСобытия["Element"];
	
	Если ЭлементHTML["id"] <> "V8WebAppEventRequestForwarder" Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Сообщение = НовоеСообщение();
	Сообщение.Вид = ЭлементHTML.getAttribute("v8kind");
	Если ПустаяСтрока(Сообщение.Вид) Тогда
		Сообщение.Вид = "request";
	КонецЕсли;
	
	Сообщение.ИмяСобытия = ЭлементHTML.getAttribute("v8eventname");
	Сообщение.Ид = ЭлементHTML.getAttribute("v8uuid");
	Сообщение.ТипЗначения = ЭлементHTML.getAttribute("v8type");
	
	Если Сообщение.ТипЗначения = "json" Или Сообщение.ТипЗначения = "string" Или Сообщение.ТипЗначения = "bool" Или Сообщение.ТипЗначения = "number" Тогда
		Сообщение.Значение = ПрочитатьЗначениеJSON(ЭлементHTML["value"]);
	ИначеЕсли Сообщение.ТипЗначения = "blob" Тогда
		Сообщение.Значение = Base64Значение(ЭлементHTML["value"]);
	ИначеЕсли Сообщение.ТипЗначения = "undefined" Тогда
		Сообщение.Значение = Неопределено;
	КонецЕсли;
	
	Сообщить(СтрШаблон(НСтр("ru = 'Получено %1(%2): %3'"), Сообщение.ИмяСобытия, Сообщение.Ид, ЭлементHTML["value"]));
	
	Попытка
		Если Сообщение.ИмяСобытия = "ShowPopUp" Тогда
			ОтправитьОтвет(ЭлементПолеHTML, Сообщение);
			ПоказатьПредупреждение(, Сообщение.Значение["text"]);
		КонецЕсли;
		
		Если Сообщение.ИмяСобытия = "GetFormAttribute" Тогда
			ОтправитьОтвет(ЭлементПолеHTML, Сообщение, ЭтотОбъект[Сообщение.Значение]);
		КонецЕсли;
		
		Если Сообщение.ИмяСобытия = "SetFormAttribute" Тогда
			ИмяРеквизита = Сообщение.Значение["key"];
			ЗначениеРеквизита = Сообщение.Значение["value"];
			
			УстановитьРеквизитФормы(ЭтотОбъект, ИмяРеквизита, ЗначениеРеквизита);
			ТекущееЗначениеРеквизита = ЭтотОбъект[ИмяРеквизита];
			
			ОтправитьОтвет(ЭлементПолеHTML, Сообщение, ТекущееЗначениеРеквизита);
			
			ИзменениеРеквизита = Новый Структура;
			ИзменениеРеквизита.Вставить("key", ИмяРеквизита);
			ИзменениеРеквизита.Вставить("value", ТекущееЗначениеРеквизита);
			ОтправитьСобытие(ЭлементПолеHTML, "FormAttributeChanged", ИзменениеРеквизита);
			
			Сообщить(СтрШаблон(НСтр("ru = 'Реквизит %1 установлен в %2'"), ИмяРеквизита, ТекущееЗначениеРеквизита));
		КонецЕсли;
		
		ВыполнитьОбработкуОповещения(Обработчик, Сообщение);
	Исключение
		Описание = ОписаниеОшибки();
		Сообщить(СтрШаблон(НСтр("ru = 'Ошибка обработки %1(%2): %3'"), Сообщение.ИмяСобытия, Сообщение.Ид, Описание));
		
		Попытка
			ОтправитьОшибка(ЭлементПолеHTML, Сообщение, Описание);
		Исключение
		КонецПопытки;
	КонецПопытки;
	
КонецПроцедуры

Процедура ОтправитьОтвет(ЭлементПолеHTML, Сообщение, Ответ = Неопределено) Экспорт
	
	ЭлементHTML = ЭлементПолеHTML.Документ["defaultView"];
	Прокси = ЭлементHTML["V8Proxy"];
	Пакет = ПодготовитьПакет(Ответ);
	
	Прокси.sendResponse(Сообщение.Ид, Пакет.Данные, Пакет.Тип);
	
	Сообщить(СтрШаблон(НСтр("ru = 'Отправлен ответ %1(%2): %3'"), Сообщение.ИмяСобытия, Сообщение.Ид, Ответ));
	
КонецПроцедуры

Процедура ОтправитьОшибка(ЭлементПолеHTML, Сообщение, ТекстОшибки) Экспорт
	
	ЭлементHTML = ЭлементПолеHTML.Документ["defaultView"];
	Прокси = ЭлементHTML["V8Proxy"];
	
	Прокси.sendError(Сообщение.Ид, ТекстОшибки);
	
	Сообщить(СтрШаблон(НСтр("ru = 'Отправлена ошибка %1(%2): %3'"), Сообщение.ИмяСобытия, Сообщение.Ид, ТекстОшибки));
	
КонецПроцедуры

Процедура ОтправитьСобытие(ЭлементПолеHTML, ИмяСобытия, Значение = Неопределено) Экспорт
	
	ЭлементHTML = ЭлементПолеHTML.Документ["defaultView"];
	Прокси = ЭлементHTML["V8Proxy"];
	Пакет = ПодготовитьПакет(Значение);
	
	Прокси.sendEvent(ИмяСобытия, Пакет.Данные, Пакет.Тип);
	
	Сообщить(СтрШаблон(НСтр("ru = 'Отправлено событие %1: %2'"), ИмяСобытия, Значение));
	
КонецПроцедуры

Процедура УстановитьРеквизитФормы(ЭтотОбъект, ИмяРеквизита, Значение)
	
	Попытка
		ЭтотОбъект.ЗначениеВРеквизитФормы(Значение, ИмяРеквизита);
	Исключение
		ЭтотОбъект[ИмяРеквизита] = Значение;
	КонецПопытки;
	
	Попытка
		ЭлементФормы = ЭтотОбъект.Элементы[ИмяРеквизита];
		Если ЭлементФормы <> Неопределено Тогда
			ЭлементФормы.Значение = Значение;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

